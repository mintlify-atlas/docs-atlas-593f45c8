  "keyFeatures": [
    "Chat with any GitHub repository using natural language",
    "RAG-powered context-aware answers from codebase",
    "Language-aware code chunking for 25+ programming languages",
    "Vector embeddings using Sentence Transformers",
    "ChromaDB vector database with cosine similarity search",
    "Groq LLM integration for intelligent responses",
    "Smart file filtering (excludes binaries, node_modules, etc.)",
    "Persistent local vector storage"
  ],
  "publicApiSurface": [
    "GitHubCodeBaseLoader.load()",
    "GitHubCodeBaseLoader.file_filter()",
    "TextSplitter.split_documents_into_chunks()",
    "EmbeddingManager.generate_embeddings()",
    "VectorStore.add_documents()",
    "RAGRetriever.retrieve()",
    "GroqLLM.rag()"
  ]
